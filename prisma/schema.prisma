// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Auth.js (NextAuth) models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")
  password      String?
  accounts      Account[]
  sessions      Session[]
  locations     BusinessLocation[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// GBP specific models
model BusinessLocation {
  id                String   @id @default(cuid())
  googleLocationId  String   @unique
  name              String
  address           String?
  phone             String?
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics           PerformanceMetric[]
  reviews           Review[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PerformanceMetric {
  id                String   @id @default(cuid())
  locationId        String
  date              DateTime
  searches          Int      @default(0)
  views             Int      @default(0)
  websiteClicks     Int      @default(0)
  phoneCalls        Int      @default(0)
  directionRequests Int      @default(0)
  location          BusinessLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, date])
}

model Review {
  id                String   @id @default(cuid())
  locationId        String
  googleReviewId    String   @unique
  reviewerName      String
  rating            Int
  comment           String?
  postedAt          DateTime
  replyText         String?
  repliedAt         DateTime?
  location          BusinessLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
}
