generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  ADMIN
  MEMBER
  READONLY
}

enum ReviewReplyStatus {
  UNHANDLED
  DRAFT
  REPLIED
}

enum AIApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  NEW_REVIEW
  UNREPLIED_ALERT
}

model Organization {
  id                String            @id @default(cuid())
  clerkOrgId        String            @unique
  name              String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  members           Member[]
  locations         BusinessLocation[]
  replyTemplates    ReplyTemplate[]
  notifications     Notification[]
}

model Member {
  id                String        @id @default(cuid())
  organizationId    String
  clerkUserId       String
  role              MemberRole
  displayName       String?
  email             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, clerkUserId])
  @@index([organizationId])
}

model BusinessLocation {
  id                String        @id @default(cuid())
  organizationId    String
  name              String
  address           String?
  googleLocationId  String        @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviews           Review[]

  @@index([organizationId])
}

model Review {
  id                String             @id @default(cuid())
  organizationId    String
  businessLocationId String
  googleReviewId    String             @unique
  reviewerName      String?
  rating            Int
  comment           String?
  reviewedAt        DateTime
  replyStatus       ReviewReplyStatus  @default(UNHANDLED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  businessLocation  BusinessLocation   @relation(fields: [businessLocationId], references: [id], onDelete: Cascade)
  reply             ReviewReply?
  drafts            AIReplyDraft[]

  @@index([organizationId])
  @@index([businessLocationId])
  @@index([replyStatus])
}

model ReviewReply {
  id                String        @id @default(cuid())
  reviewId          String        @unique
  organizationId    String
  body              String
  postedAt          DateTime?
  createdByClerkUserId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  review            Review        @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AIReplyDraft {
  id                String            @id @default(cuid())
  reviewId          String
  organizationId    String
  body              String
  approvalStatus    AIApprovalStatus  @default(PENDING)
  generatedBy       String?
  approvedBy        String?
  rejectedReason    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  review            Review            @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([reviewId])
  @@index([approvalStatus])
}

model ReplyTemplate {
  id                String        @id @default(cuid())
  organizationId    String
  name              String
  starRating        Int?
  body              String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Notification {
  id                String            @id @default(cuid())
  organizationId    String
  type              NotificationType
  title             String
  body              String?
  readAt            DateTime?
  createdAt         DateTime          @default(now())
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
}
